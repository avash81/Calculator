# CalcPro.NP — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# ── FIREBASE (Required for Auth/Blog/SEO) ─────────────────────────
# Get these from Firebase Console → Project Settings → Your Apps
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_DATABASE_ID=your_firestore_database_id

# ── AI ENGINE (Required for Math Solver) ──────────────────────────
# Get this from Google AI Studio (aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# ── SECURITY (Required for Admin Access) ─────────────────────────
# This must match the token used for admin login
ADMIN_SECRET_TOKEN=calcpro-admin-2082-nepal

# ── SITE CONFIGURATION ───────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://calcpro.com.np
